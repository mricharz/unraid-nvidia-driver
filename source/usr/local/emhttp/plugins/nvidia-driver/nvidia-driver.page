<?php
//Get selected driver version
$selected_v = shell_exec("/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh get_selected_version");

//Update driver versions and create file '/tmp/nvidia_driver'
shell_exec('/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh update');

//Get latest version
$latest_v = shell_exec('/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh get_latest_version');

//Get branch versions
$latest_prb_v = shell_exec('/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh get_prb');
$latest_nfb_v = shell_exec('/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh get_nfb');
$latest_beta_v = shell_exec('/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh get_beta');
$latest_nos_v = shell_exec('/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh get_nos');

//Get driver license
$module_license = shell_exec('/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh get_license');

//Get current installed driver version
$installed_v = shell_exec('/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh get_installed_version');

//Get GPU architecture (compute capability)
$gpu_arch = trim(shell_exec('/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh get_gpu_arch'));

//Get CUDA version
$cuda_v = trim(shell_exec('/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh get_cuda_version'));

//Determine if GPU is Blackwell or newer (compute capability >= 10.0)
$is_blackwell = false;
if (!empty($gpu_arch)) {
  $arch_num = floatval($gpu_arch);
  $is_blackwell = ($arch_num >= 10.0);
}

//Map compute capability to architecture name
$arch_name = '';
if (!empty($gpu_arch)) {
  $arch_num = floatval($gpu_arch);
  if ($arch_num >= 12.0) $arch_name = 'Blackwell';
  elseif ($arch_num >= 10.0) $arch_name = 'Blackwell';
  elseif ($arch_num >= 8.9) $arch_name = 'Ada Lovelace';
  elseif ($arch_num >= 8.6) $arch_name = 'Ampere';
  elseif ($arch_num >= 8.0) $arch_name = 'Ampere';
  elseif ($arch_num >= 7.5) $arch_name = 'Turing';
  elseif ($arch_num >= 7.0) $arch_name = 'Volta';
  elseif ($arch_num >= 6.0) $arch_name = 'Pascal';
  else $arch_name = 'Legacy';
}

//Read driver versions from '/tmp/nvidia_driver'
error_reporting(E_ALL);
ini_set('display_errors',1);

//Get value from update check
$update_check = shell_exec("/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh update_check");

$filename = "/tmp/nvidia_driver";
$eachlines = file($filename, FILE_IGNORE_NEW_LINES);

//Read open source driver versions
$nvos_versions = array();
if (file_exists("/tmp/nvos_driver")) {
  $nvos_lines = file("/tmp/nvos_driver", FILE_IGNORE_NEW_LINES);
  if ($nvos_lines !== false) {
    $nvos_versions = $nvos_lines;
  }
}

//Get installed driver version
$cur_drv_v = shell_exec("nvidia-smi | grep \"Driver Version\" | cut -d ' ' -f3");
if (empty($cur_drv_v)) {
  $cur_drv_v = shell_exec("nvidia-settings --help | grep -oP '(?<=version )[\d\.]+'");
  if (empty($cur_drv_v)) {
    $cur_drv_v = "ERROR: No driver found!";
  }
}

//Get Unraid driver version
$unraid_version = parse_ini_file('/etc/unraid-version');
?>

<script>
    //Don't execute commands again if page is refreshed
    if ( window.history.replaceState ) {
        window.history.replaceState( null, null, window.location.href );
    }
</script>

<script>
function changeVersion(form) {
    var pkg = form.drv_version.value;
    openBox("/usr/local/emhttp/plugins/nvidia-driver/include/exec.sh&arg1=update_version&arg2="+pkg,"Downloading Package",600,800,true);
    return false;
}

function filterVersions() {
    var moduleType = document.getElementById('module_type').value;
    var versionSelect = document.getElementById('drv_version');
    var options = versionSelect.querySelectorAll('option');
    var blackwellWarning = document.getElementById('blackwell-warning');
    var isBlackwell = <?php echo $is_blackwell ? 'true' : 'false'; ?>;

    options.forEach(function(opt) {
        var val = opt.value;
        if (moduleType === 'opensource') {
            // Show open source options, hide proprietary-only
            if (val === 'latest_nos') {
                opt.style.display = '';
            } else if (val === 'latest' || val === 'latest_prb' || val === 'latest_nfb' || val === 'latest_beta') {
                opt.style.display = 'none';
            } else {
                // Specific versions: hide versions below 560 (no open source support)
                var ver = parseFloat(val);
                if (!isNaN(ver) && ver < 560) {
                    opt.style.display = 'none';
                } else {
                    opt.style.display = '';
                }
            }
        } else {
            // Show proprietary options, hide open-source-only
            if (val === 'latest_nos') {
                opt.style.display = 'none';
            } else {
                opt.style.display = '';
            }
        }
    });

    // Show/hide optgroups based on content visibility
    var optgroups = versionSelect.querySelectorAll('optgroup');
    optgroups.forEach(function(og) {
        var visibleOpts = og.querySelectorAll('option:not([style*="display: none"])');
        og.style.display = visibleOpts.length > 0 ? '' : 'none';
    });

    // Reset selection if current selection is hidden
    var selectedOpt = versionSelect.options[versionSelect.selectedIndex];
    if (selectedOpt && selectedOpt.style.display === 'none') {
        // Select the first visible option
        for (var i = 0; i < versionSelect.options.length; i++) {
            if (versionSelect.options[i].style.display !== 'none') {
                versionSelect.selectedIndex = i;
                break;
            }
        }
    }

    // Show Blackwell warning when proprietary is selected on Blackwell GPU
    if (blackwellWarning) {
        blackwellWarning.style.display = (moduleType === 'proprietary' && isBlackwell) ? 'block' : 'none';
    }
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    filterVersions();
});
</script>

